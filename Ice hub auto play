local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local gui = Instance.new("ScreenGui")
gui.Name = "UpdateWarning"
gui.ResetOnSpawn = false
gui.Parent = playerGui

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 450, 0, 250)
frame.Position = UDim2.new(0.5, -225, 0.5, -125)
frame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
frame.BorderColor3 = Color3.fromRGB(255, 255, 255)
frame.BorderSizePixel = 2
frame.Parent = gui

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, 0, 0, 40)
title.BackgroundTransparency = 1
title.Text = "⚠ WARNING ⚠"
title.Font = Enum.Font.GothamBold
title.TextScaled = true
title.TextColor3 = Color3.fromRGB(255, 80, 80)
title.Parent = frame

local textLabel = Instance.new("TextLabel")
textLabel.Size = UDim2.new(1, -20, 1, -50)
textLabel.Position = UDim2.new(0, 10, 0, 45)
textLabel.BackgroundTransparency = 1
textLabel.Font = Enum.Font.GothamBold
textLabel.TextColor3 = Color3.fromRGB(255,255,255)
textLabel.TextScaled = false
textLabel.TextSize = 20
textLabel.TextWrapped = true
textLabel.Parent = frame

RunService.RenderStepped:Connect(function()
	local agora = os.date("*t")

	local alvo = {
		year = agora.year,
		month = agora.month,
		day = agora.day,
		hour = 20,
		min = 0,
		sec = 0
	}

	local restante = os.time(alvo) - os.time()

	if restante <= 0 then
		textLabel.Text = [[
SCRIPT AVAILABLE!

UPDATE FINALIZADO.
OBRIGADO PELA PACIÊNCIA.
]]
		return
	end

	local horas = math.floor(restante / 3600)
	local minutos = math.floor((restante % 3600) / 60)
	local segundos = restante % 60

	textLabel.Text = string.format(
[[SCRIPT UNDER UPDATE

MOTIVO:
ESTOU INDO PARA O CURSO
E AO MESMO TEMPO
ATUALIZANDO

TEMPO RESTANTE:
%02d:%02d:%02d]],
		horas,
		minutos,
		segundos
	)
end)
